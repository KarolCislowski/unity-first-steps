# Unity projects in this repository (multiple project folders)
# Keep source assets and project settings, ignore generated/editor-local files.

# Auto-generated by Unity
**/[Ll]ibrary/
**/[Tt]emp/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/[Ll]ogs/
**/[Mm]emoryCaptures/
**/[Rr]ecordings/

# Addressables generated local data
**/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# User-specific settings
**/[Uu]ser[Ss]ettings/

# Visual Studio / Rider / VS Code generated files
.vs/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta for temporary files
**/[Ss]ys[Ii]nfo/

# Gradle / Android
**/.gradle/
**/gradleOutput/

# Crash reports
sysinfo.txt

# macOS noise
.DS_Store

# Optional: uncomment if you never want local package caches in repo root
# /Library/
# /Temp/
